# Copy to .env (gitignored) or store in Infisical (see docs/secrets.md).
# Never commit real values.

BS_ACCOUNT=
BS_PASSWORD=
BS_ACCOUNT_CODE=default

BS_MODEL_PATH=models/common_old.onnx
BS_CHARSET_PATH=models/charset.json
BS_SESSION_PATH=.session.json
BS_BASE_URL=https://www.bigseller.com
BS_OCR_THREADS=4
BS_LOGIN_ATTEMPTS=8

DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

API_BIND=0.0.0.0:8080
API_TOKEN=change-me

SYNC_NEW_INTERVAL_SECS=60
CANCEL_HOUR_LOCAL=17
CANCEL_MINUTE_LOCAL=0
AUTO_RELOGIN=true

# WA_WEBHOOK_URL=
# WA_WEBHOOK_TOKEN=

# Wazapin — instant order PNG → WhatsApp group (worker outbox)
# WAZAPIN_API_KEY=wzp_...
# WAZAPIN_CHANNEL_ID=wzp_...
# WAZAPIN_GROUP_JID=120363...@g.us
# WAZAPIN_BASE_URL=https://api.wazapin.com
# WAZAPIN_ORG_SLUG=
# WAZAPIN_NOTIFY_INSTANT=true
# WAZAPIN_NOTIFY_CANCEL=true
